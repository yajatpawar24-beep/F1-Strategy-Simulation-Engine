{
  "version": 2,
  "builds": [
    {
      "src": "api/main_v2.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/frontend/(.*)",
      "dest": "/frontend/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/main_v2.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index_v3.html"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
